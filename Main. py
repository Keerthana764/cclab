Multiplication of 2 matrices
main.py
from flask import Flask, jsonify

app = Flask(__name__)

@app.route("/")
def multiply():

    A = [[1, 2], [3, 4]]
    B = [[5, 6], [7, 8]]

    # Matrix multiplication
    result = [[sum(A[i][k] * B[k][j] for k in range(2))
              for j in range(2)] for i in range(2)]

    return jsonify({
        "matrix_A": A,
        "matrix_B": B,
        "result": result
    })

if __name__ == "__main__":
    app.run(port=8080)

